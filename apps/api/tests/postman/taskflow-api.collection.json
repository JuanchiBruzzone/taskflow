          "name": "Crear tarea (US-05) y capturar task_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Tarea creada con status TODO', () => {",
                  " pm.response.to.have.status(201);",
                  " const body = pm.response.json();",
                  " pm.expect(body.status).to.eql('TODO');",
                  " pm.environment.set('task_id', body.id);",
                  "});",
                  "",
                  "pm.test('Priority HIGH se persistió correctamente', () => {",
                  " pm.expect(pm.response.json().priority).to.eql('HIGH');",
                  "});"
