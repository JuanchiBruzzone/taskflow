      "item": [
        {
          "name": "Registro de usuario (US-01)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => {",
                  " pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response tiene id y email', () => {",
                  " const body = pm.response.json();",
                  " pm.expect(body).to.have.property('id');",
                  " pm.expect(body.email).to.eql('ana@ejemplo.com');",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n \"name\": \"Ana García\",\n \"email\": \"ana@ejemplo.com\",\n \"password\": \"Segura123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "US-01 — Registro de usuario  \nCA verificado: Email con formato válido y password válida permiten registrar un usuario  \nTipo de test: Funcional — happy path  \nResultado esperado: 201 Created con body que incluye id y email\n\nUS-01 — Registro de usuario  \nCA verificado: La password debe tener mínimo 8 caracteres  \nTipo de test: Funcional — edge case  \nResultado esperado: 400 Bad Request con body.message descriptivo"
