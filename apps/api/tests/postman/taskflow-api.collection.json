    {
      "name": "Proyectos",
      "item": [
        {
          "name": "Crear proyecto (US-03)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Proyecto creado con status 201', () => {",
                  " pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response tiene id, name y status activo', () => {",
                  " const body = pm.response.json();",
                  " pm.expect(body.id).to.be.a('string');",
                  " pm.expect(body.name).to.eql('Mi proyecto de testing');",
                  " // Guardar ID para los siguientes requests",
                  " pm.environment.set('project_id', body.id);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
