{
  "name": "@taskflow/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
  "test": "node --env-file=.env.test ./node_modules/.bin/vitest run",
    "test:unit": "vitest run tests/unit --coverage",
  "test:integration": "node --env-file=.env.test ./node_modules/.bin/vitest run tests/integration",
    "test:bdd": "cucumber-js",
  "test:watch": "node --env-file=.env.test ./node_modules/.bin/vitest",
  "db:migrate:test": "node --env-file=.env.test npx prisma migrate deploy --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "vite": "8.0.10",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx src/prisma/seed.ts"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.4.0",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "tsx": "^4.11.2",
    "vitest": "^4.1.5"
  }
}
