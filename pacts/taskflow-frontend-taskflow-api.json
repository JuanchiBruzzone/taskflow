{
  "consumer": {
    "name": "taskflow-frontend"
  },
  "interactions": [
    {
      "description": "una petición para crear proyecto TaskFlow MVP",
      "pending": false,
      "providerStates": [
        {
          "name": "usuario autenticado con token válido"
        }
      ],
      "request": {
        "body": {
          "content": {
            "description": "desc",
            "name": "TaskFlow MVP"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Authorization": [
            "Bearer token-de-test"
          ],
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/projects"
      },
      "response": {
        "body": {
          "content": {
            "id": "e2490de5-5bd3-43d5-b7c4-526e33f71304",
            "name": "TaskFlow MVP",
            "ownerId": "e2490de5-5bd3-43d5-b7c4-526e33f71304"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "generators": {
          "body": {
            "$.id": {
              "type": "Uuid"
            },
            "$.ownerId": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.ownerId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            }
          }
        },
        "status": 201
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.1"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "taskflow-api"
  }
}