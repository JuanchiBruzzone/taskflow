{
  "name": "taskflow",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "taskflow-bdd"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:unit": "npm run test:unit --workspace=apps/api",
    "test:integration": "npm run test:integration --workspace=apps/api",
    "test:bdd": "cucumber-js --profile auth --config taskflow-bdd/cucumber.cjs && cucumber-js --profile projects --config taskflow-bdd/cucumber.cjs && cucumber-js --profile tasks --config taskflow-bdd/cucumber.cjs",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:bdd && npm run test:e2e",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "test:mobile": "cd mobile && npx wdio run wdio.conf.ts",
    "test": "vitest run --config apps/api/vitest.config.ts",
    "test:watch": "vitest --config apps/api/vitest.config.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run test && npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@eslint/js": "^10.0.1",
    "@pact-foundation/pact": "^16.3.1",
    "@playwright/test": "^1.44.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "allure-commandline": "^2.42.1",
    "allure-js-commons": "^3.9.0",
    "allure-vitest": "^3.9.0",
    "concurrently": "^8.2.2",
    "globals": "^17.4.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "vite": "8.0.10"
  }
}
